//Write a shell script to read n numbers as command arguments and sort them in descending order. 

if [ $# -eq 0 ]
then
    echo "No numbers entered"
    exit
fi

arr=("$@")
n=$#

for ((i=0; i<n; i++))
do
    for ((j=0; j<n-i-1; j++))
    do
        if [ ${arr[j]} -lt ${arr[j+1]} ]
        then
            temp=${arr[j]}
            arr[j]=${arr[j+1]}
            arr[j+1]=$temp
        fi
    done
done

echo "Input numbers:"
echo "$@"

echo "Sorted numbers:"
echo "${arr[@]}"
